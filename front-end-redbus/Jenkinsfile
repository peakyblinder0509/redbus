pipeline {
    agent any

    environment {
        AWS_REGION = "ap-south-1"
        S3_BUCKET = "krishnagiri-bargur"
        CLOUDFRONT_DISTRIBUTION_ID = "E35FULF7FODTGJ"
    }

    stages {

        stage('Checkout') {
            steps {
                git branch: 'master',
                    credentialsId: 'pat-creds',
                    url: 'https://github.com/peakyblinder0509/redbus.git'
            }
        }

        stage('Check Node Version') {
            steps {
                dir('front-end-redbus') {
                    sh '''
                        echo "Node version:"
                        node -v
                        echo "NPM version:"
                        npm -v
                    '''
                }
            }
        }

        stage('Install Dependencies') {
            steps {
                dir('front-end-redbus') {
                    sh '''
                        echo "Cleaning old dependencies..."
                        rm -rf node_modules package-lock.json
                        echo "Installing dependencies..."
                        npm install --legacy-peer-deps
                        echo "Fixing postcss issue..."
                        npm install postcss@8.4.31 --save-dev
                    '''
                }
            }
        }

        stage('Build') {
            steps {
                dir('front-end-redbus') {
                    sh '''
                        export NODE_OPTIONS="--openssl-legacy-provider --max-old-space-size=2048"
                        CI=false npm run build
                    '''
                }
            }
        }

        stage('Verify Build Output') {
            steps {
                dir('front-end-redbus') {
                    sh '''
                        echo "Checking build folder..."
                        ls -la build || (echo "build folder not found!" && exit 1)
                        echo "âœ… Build folder verified"
                    '''
                }
            }
        }

        stage('Deploy to S3') {
            steps {
                withAWS(credentials: 'shana-cred', region: "${AWS_REGION}") {
                    sh '''
                        echo "Deploying to S3 bucket: ${S3_BUCKET}"
                        aws s3 sync front-end-redbus/build/ s3://${S3_BUCKET}/ --delete
                        echo "âœ… S3 deployment completed"
                    '''
                }
            }
        }

        stage('CloudFront Invalidation') {
            steps {
                withAWS(credentials: 'shana-cred', region: "${AWS_REGION}") {
                    sh '''
                        echo "Invalidating CloudFront cache..."
                        aws cloudfront create-invalidation \
                            --distribution-id ${CLOUDFRONT_DISTRIBUTION_ID} \
                            --paths "/*"
                        echo "âœ… CloudFront invalidation completed"
                    '''
                }
            }
        }
    }

    post {
        success {
            echo "âœ… Frontend deployed successfully!"
            echo "ðŸŒ Website: http://${S3_BUCKET}.s3-website.${AWS_REGION}.amazonaws.com"
        }
        failure {
            echo "âŒ Frontend deployment failed. Check console logs above."
        }
    }
}
